rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidVideo() {
      return request.resource.contentType == 'video/mp4'
        && request.resource.size < 500 * 1024 * 1024; // 500MB
    }

    // ── Video uploads ─────────────────────────────────────────────────────
    match /videos/{userId}/{matchId}/{filename} {
      // Authenticated owner can upload valid MP4s
      allow create: if isAuthenticated()
        && isOwner(userId)
        && isValidVideo();

      // Owner can read their own videos
      allow read: if isAuthenticated() && isOwner(userId);

      // Owner can delete their own videos
      allow delete: if isAuthenticated() && isOwner(userId);

      // No updates (immutable once uploaded)
      allow update: if false;
    }

    // ── Thumbnails (generated by Cloud Functions) ─────────────────────────
    match /thumbnails/{userId}/{matchId}/{filename} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if false; // Cloud Functions only
    }

    // ── Exports ───────────────────────────────────────────────────────────
    match /exports/{userId}/{filename} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if false; // Cloud Functions only
    }
  }
}
