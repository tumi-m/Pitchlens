# API Security
API_SECRET_KEY=your_strong_secret_key_min_32_chars

# Roboflow
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_WORKSPACE=your_workspace_slug
ROBOFLOW_PROJECT=football-players-detection-3zvbc
ROBOFLOW_VERSION=9

# Firebase / Google
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# App
PORT=8080
ENV=production
ALLOWED_ORIGINS=https://pitchlens.vercel.app,https://pitchlens.app
FRAME_SUBSAMPLE=5
PIPELINE_WORKERS=2

# Logging
LOG_LEVEL=INFO
